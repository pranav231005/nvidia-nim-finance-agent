# ============================================================================
# Autonomous AI Agent System — Configuration
# ============================================================================
# Copy to .env: cp .env.example .env

# --- Application ---
APP_NAME=autonomous-ai-agent
ENVIRONMENT=development
DEBUG=false
TIMEZONE=Asia/Kolkata
LOCAL_STORAGE_PATH=./artifacts
LOG_LEVEL=INFO

# --- LLM Provider ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=deepseek-ai/deepseek-v4-pro
DEFAULT_LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=3

# --- Memory ---
CHROMA_PERSIST_DIRECTORY=./artifacts/chromadb
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
SHORT_TERM_MEMORY_LIMIT=100
EPISODIC_MEMORY_LIMIT=500
VECTOR_SEARCH_TOP_K=5
MEMORY_SIMILARITY_THRESHOLD=0.7

# --- Task Queue ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
TASK_TIMEOUT_SECONDS=600
MAX_CONCURRENT_TASKS=5

# --- Database ---
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=*
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# --- Execution ---
MAX_AUTONOMOUS_STEPS=50
MAX_RETRIES_PER_TASK=3
EXECUTION_TIMEOUT_SECONDS=3600
MAX_TOOL_CALLS_PER_STEP=5
RECURSION_DEPTH_LIMIT=10
INTERRUPTION_RECOVERY_ENABLED=true

# --- Safety & Guardrails ---
REQUIRE_HUMAN_APPROVAL=false
HUMAN_APPROVAL_FOR=file_delete,git_push,shell_destructive,code_exec
ALLOWED_DOMAINS=
BLOCKED_DOMAINS=
MAX_COST_PER_SESSION_USD=50.0
MAX_TOKENS_PER_SESSION=1000000
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT_SECONDS=30

# --- Finance ---
TICKERS=AAPL,MSFT,GOOGL,AMZN,TSLA
YAHOO_FINANCE_ENABLED=true
NEWSAPI_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
SEC_API_KEY=

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_DEFAULT_ORG=

# --- Email ---
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- AWS ---
S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Observability ---
TELEMETRY_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=
METRICS_PORT=9090