APP_NAME=finance-ai-agent
ENVIRONMENT=production
TIMEZONE=Asia/Kolkata
RUN_HOUR=0
RUN_MINUTE=0
DATA_LOOKBACK_HOURS=24
NEWS_LIMIT_PER_TICKER=8
MACRO_NEWS_LIMIT=10
LOCAL_STORAGE_PATH=./artifacts
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=20
RETRY_ATTEMPTS=3
RETRY_MIN_SECONDS=2
RETRY_MAX_SECONDS=8

TICKERS=AAPL,TSLA,RELIANCE.NS

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

NEWSAPI_API_KEY=your_newsapi_key
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email_username
SMTP_PASSWORD=your_email_password_or_app_password
EMAIL_FROM=alerts@example.com
EMAIL_TO=investor1@example.com,investor2@example.com
EMAIL_SUBJECT_PREFIX=[Finance AI]

WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+911234567890

S3_BUCKET=your_reports_bucket
S3_PREFIX=finance-agent
S3_PUBLIC_BASE_URL=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

REPORT_RETENTION_DAYS=30
